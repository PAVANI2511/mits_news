# MongoDB Configuration (optional, defaults to local or mongomock)
MONGO_URI=mongodb://localhost:27017
MONGO_DB_NAME=mits_newspaper

# SMTP Email Configuration (configure these to send actual emails via OTP)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
DEFAULT_FROM_EMAIL=your-email@gmail.com
